    "Kiran",
    "Arul",
    "Renga",
    "Stellas",
    "Sharath",
    "Derick"
};

String get_name_from_address(int addr){
    if(addr >= 1 && addr <= 8){
        return String(names[addr - 1]);
    }
    return String("Unknown");
}

void loraAT(String cmd){
    while(LoRa.available()) LoRa.read();
    LoRa.print(cmd + "\r\n");  // not println
    delay(600);
    String r = "";
    while(LoRa.available()) r += (char)LoRa.read();
    r.trim();
    Serial.println(cmd + " => " + (r.length() ? r : "NO RESPONSE"));
}

